# Copy to `.env` and fill in. NEVER commit a real `.env` — it is gitignored.
# In production the app refuses to boot unless the security-critical values
# below are set safely (see settings.validate_production_safety).

# development | staging | production. `production` enforces the checks below.
INBOXREADY_ENVIRONMENT=development

INBOXREADY_HTTP_TIMEOUT_SECONDS=5.0
INBOXREADY_USER_AGENT=InboxReady/1.0 (+https://example.com)
INBOXREADY_DATABASE_PATH=var/inboxready.sqlite3
INBOXREADY_OBJECT_STORE_PATH=var/object-store
# Must be https:// in production.
INBOXREADY_PUBLIC_BASE_URL=http://127.0.0.1:8000
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotate if it ever leaks — all existing sessions are invalidated.
INBOXREADY_SESSION_SECRET=replace-with-at-least-32-random-characters
# Must be true in production so session cookies are marked Secure + HSTS is sent.
INBOXREADY_SESSION_HTTPS_ONLY=false
# SSRF guard: only enable against trusted local test servers, never in production.
INBOXREADY_ALLOW_PRIVATE_NETWORK_FETCHES=false
INBOXREADY_COMPANY_NAME=InboxReady
INBOXREADY_SUPPORT_EMAIL=support@inboxready.dev
INBOXREADY_PUBLIC_SIGNUP_ENABLED=true
INBOXREADY_API_AUTH_REQUIRED=true
INBOXREADY_ALLOW_UNPAID_PLAN_PROVISIONING=false
INBOXREADY_DEMO_DAILY_LIMIT=20
INBOXREADY_DEMO_RATE_LIMIT_PER_MINUTE=5
INBOXREADY_BATCH_MAX_WORKERS=5

# Stripe is optional for local development. Configure these before using
# /v1/billing/checkout, /v1/billing/portal, or /v1/billing/webhook.
INBOXREADY_STRIPE_SECRET_KEY=
INBOXREADY_STRIPE_WEBHOOK_SECRET=
INBOXREADY_STRIPE_STARTER_PRICE_ID=
INBOXREADY_STRIPE_GROWTH_PRICE_ID=
INBOXREADY_STRIPE_PRO_PRICE_ID=
