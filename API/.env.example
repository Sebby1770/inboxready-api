# HTTP client used for MTA-STS policy fetch
INBOXREADY_HTTP_TIMEOUT_SECONDS=5.0
INBOXREADY_USER_AGENT=InboxReady/0.2 (+https://example.com)

# Comma-separated API keys. When non-empty, X-API-Key is required on /v1/* routes.
# Leave empty for an open local/demo deployment.
INBOXREADY_API_KEYS=

# Force API key requirement even when INBOXREADY_API_KEYS is empty.
INBOXREADY_REQUIRE_API_KEY=false

# Sliding-window rate limit per API key (or client IP when unauthenticated).
# Set to 0 to disable.
INBOXREADY_RATE_LIMIT_PER_MINUTE=60

# In-memory TTL cache for domain audit results (seconds). 0 disables caching.
INBOXREADY_CACHE_TTL_SECONDS=300

# Thread pool size for concurrent batch domain audits.
INBOXREADY_BATCH_MAX_WORKERS=8

# v0.3
INBOXREADY_HISTORY_MAX_ENTRIES=500
INBOXREADY_HISTORY_PATH=
INBOXREADY_WEBHOOK_URL=
INBOXREADY_WEBHOOK_MIN_SCORE=70
